; Engine configuration file for the Clock example.
config_version=5

[application]

config/name="Clock"
config/features=PackedStringArray("4.4", "Forward Plus") ; Assuming Godot 4.4+ features
config/icon="res://icon.svg"
run/main_scene="res://clock_main.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"

[rendering]

environment/defaults/default_clear_color=Color(0.294118, 0, 0.509804, 1) ; Indigo
